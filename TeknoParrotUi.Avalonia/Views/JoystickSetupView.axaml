<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TeknoParrotUi.Avalonia.Views.JoystickSetupView">
    <DockPanel Margin="12">
        <TextBlock Name="Header" DockPanel.Dock="Top" FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock Name="ApiText" DockPanel.Dock="Top" Opacity="0.7" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Center">
            <Button Name="BtnBack" Content="Back" Width="180" Click="BtnBack_Click" />
            <Button Name="BtnSave" Content="Save Bindings" Width="180" Click="BtnSave_Click" />
        </StackPanel>
        <ScrollViewer>
            <StackPanel Name="RowsPanel" Spacing="2" MaxWidth="760" HorizontalAlignment="Left" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
