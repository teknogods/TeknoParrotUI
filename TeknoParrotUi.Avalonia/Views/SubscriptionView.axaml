<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TeknoParrotUi.Avalonia.Views.SubscriptionView">
    <StackPanel Margin="24" Spacing="10" MaxWidth="620" HorizontalAlignment="Left">
        <TextBlock Classes="h1" Text="Subscription" />
        <TextBlock TextWrapping="Wrap"
                   Text="Subscribers get early access to selected games. Enter your serial key below to activate this machine." />
        <Button Name="GameCountButton" Padding="0" Background="Transparent" BorderThickness="0"
                Cursor="Hand" Click="GameCountButton_Click"
                ToolTip.Tip="Click to see all subscription games">
            <TextBlock Name="GameCountText" Foreground="{DynamicResource SystemAccentColor}"
                       FontWeight="SemiBold" TextDecorations="Underline" />
            <Button.Flyout>
                <Flyout Placement="Bottom">
                    <StackPanel Width="340" Spacing="6">
                        <TextBlock Classes="h2" Text="Subscription games" />
                        <ScrollViewer MaxHeight="320">
                            <ItemsControl Name="SubGamesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock Text="{Binding}" FontSize="12" Margin="0,1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
        </Button>
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,6,0,0">
            <TextBlock Text="Serial key" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBox Name="KeyBox" Grid.Column="1" Watermark="XXXX-XXXX-XXXX-XXXX" />
            <ToggleButton Name="BtnReveal" Grid.Column="2" Content="👁" Margin="4,0,0,0"
                          IsVisible="False" ToolTip.Tip="Show/hide serial key"
                          IsCheckedChanged="BtnReveal_IsCheckedChanged" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Name="BtnRegister" Classes="primary" Content="Register" Click="BtnRegister_Click" />
            <Button Name="BtnDeregister" Content="Deactivate" Click="BtnDeregister_Click" IsVisible="False" />
            <Button Content="Get a Subscription" Click="BtnWebsite_Click" />
        </StackPanel>
        <Border Classes="card">
            <ScrollViewer MaxHeight="180">
                <TextBlock Name="ConsoleText" FontFamily="Consolas,monospace" FontSize="11" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
