<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TeknoParrotUi.Avalonia.Views.AboutView">
    <StackPanel Margin="24" Spacing="10" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock FontSize="22" FontWeight="Bold" Text="TeknoParrot" />
        <TextBlock Name="VersionText" Opacity="0.7" />
        <TextBlock TextWrapping="Wrap"
                   Text="Open source JVS and I/O emulation for arcade games. This is the cross-platform Avalonia interface sharing its core with the classic Windows UI." />
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Name="BtnWebsite" Content="Website" Click="BtnWebsite_Click" />
            <Button Name="BtnGitHub" Content="GitHub" Click="BtnGitHub_Click" />
            <Button Name="BtnDiscord" Content="Discord" Click="BtnDiscord_Click" />
        </StackPanel>
    </StackPanel>
</UserControl>
