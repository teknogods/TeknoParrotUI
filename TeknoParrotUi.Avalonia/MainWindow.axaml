<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TeknoParrotUi.Avalonia.MainWindow"
        Title="TeknoParrot"
        Width="1000" Height="680"
        MinWidth="800" MinHeight="500">
    <DockPanel>
        <StackPanel DockPanel.Dock="Left" Width="160" Margin="8" Spacing="4">
            <TextBlock Text="TeknoParrot" FontSize="18" FontWeight="Bold" Margin="8,8,8,16" />
            <Button Name="NavLibrary" Content="Library" HorizontalAlignment="Stretch" Click="NavLibrary_Click" />
            <Button Name="NavOnline" Content="Online" HorizontalAlignment="Stretch" Click="NavOnline_Click" />
            <Button Name="NavUpdates" Content="Updates" HorizontalAlignment="Stretch" Click="NavUpdates_Click" />
            <Button Name="NavMods" Content="Mods" HorizontalAlignment="Stretch" Click="NavMods_Click" />
            <Button Name="NavAccount" Content="Account" HorizontalAlignment="Stretch" Click="NavAccount_Click" />
            <Button Name="NavSettings" Content="Settings" HorizontalAlignment="Stretch" Click="NavSettings_Click" />
            <Button Name="NavAbout" Content="About" HorizontalAlignment="Stretch" Click="NavAbout_Click" />
        </StackPanel>
        <Border DockPanel.Dock="Bottom" Padding="12,6" Opacity="0.8">
            <TextBlock Name="StatusBar" FontSize="12" />
        </Border>
        <ContentControl Name="ContentHost" />
    </DockPanel>
</Window>
