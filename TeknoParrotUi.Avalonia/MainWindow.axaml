<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:TeknoParrotUi.Avalonia.Views"
        x:Class="TeknoParrotUi.Avalonia.MainWindow"
        Title="TeknoParrot"
        Icon="/Assets/teknoparrot.ico"
        Width="960" Height="640"
        MinWidth="640" MinHeight="440">
    <!-- Thin desktop shell: the entire UI lives in Views/MainView so it can
         also be hosted by the Android single-view lifetime. This window only
         owns desktop concerns: title/icon, size, fullscreen, close. -->
    <views:MainView Name="Root" />
</Window>
