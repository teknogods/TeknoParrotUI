<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TeknoParrotUi.Avalonia.MainWindow"
        Title="TeknoParrot"
        Icon="/Assets/teknoparrot.ico"
        Width="960" Height="640"
        MinWidth="640" MinHeight="440">
    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SystemAccentColorDark3}" Padding="8,6">
            <DockPanel>
                <Button Name="BtnMenu" DockPanel.Dock="Left" Content="☰"
                        Background="Transparent" Foreground="White" FontSize="16"
                        Padding="8,2" Click="BtnMenu_Click" />
                <TextBlock DockPanel.Dock="Left" Text="TeknoParrot" Foreground="White"
                           FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0" />
                <Border Name="SubBadge" DockPanel.Dock="Left" CornerRadius="8" Padding="7,2"
                        Margin="8,0,0,0" VerticalAlignment="Center" Background="#30FFFFFF">
                    <TextBlock Name="SubStatusText" FontSize="11" Foreground="White" />
                </Border>
                <TextBlock Name="PageTitle" Foreground="#C0FFFFFF" FontSize="13"
                           VerticalAlignment="Center" Margin="16,0,0,0" />
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="10,4" Background="#15808080">
            <TextBlock Name="StatusBar" FontSize="11" Opacity="0.85" />
        </Border>

        <!-- Collapsible navigation sidebar -->
        <Border Name="Sidebar" DockPanel.Dock="Left" Width="150" Background="#12808080" Padding="6">
            <StackPanel Spacing="2">
                <Button Name="NavLibrary" Classes="nav active" Content="🎮  Library" Click="NavLibrary_Click" />
                <Button Name="NavOnline" Classes="nav" Content="🌐  Online" Click="NavOnline_Click" />
                <Button Name="NavUpdates" Classes="nav" Content="⬇  Updates" Click="NavUpdates_Click" />
                <Button Name="NavMods" Classes="nav" Content="🧩  Mods" Click="NavMods_Click" />
                <Button Name="NavSubscription" Classes="nav" Content="⭐  Subscription" Click="NavSubscription_Click" />
                <Button Name="NavAccount" Classes="nav" Content="👤  Account" Click="NavAccount_Click" />
                <Button Name="NavSettings" Classes="nav" Content="⚙  Settings" Click="NavSettings_Click" />
                <Button Name="NavUiOptions" Classes="nav" Content="🕹  UI Options" Click="NavUiOptions_Click" />
                <Button Name="NavAbout" Classes="nav" Content="ℹ  About" Click="NavAbout_Click" />
            </StackPanel>
        </Border>

        <ContentControl Name="ContentHost" />
    </DockPanel>
</Window>
