<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TeknoParrotUi.Avalonia.App"
             RequestedThemeVariant="Default">
    <!-- "Default" follows the system dark/light theme; ThemeManager overrides
         it at startup from the saved UiOptions choice (System/Light/Dark). -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Semantic design tokens (Tp*) — all colors live here -->
                <ResourceInclude Source="/Themes/Palette.axaml" />
                <!-- Vector icons (PathIcon geometry) -->
                <ResourceInclude Source="/Themes/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Brand the built-in Fluent controls (CheckBox, ComboBox, Slider…)
                 with the TeknoParrot violet so they match the Tp accent. -->
            <Color x:Key="SystemAccentColor">#6C5CE7</Color>
            <Color x:Key="SystemAccentColorDark1">#5B4BD4</Color>
            <Color x:Key="SystemAccentColorDark2">#4E3FBF</Color>
            <Color x:Key="SystemAccentColorDark3">#4234A6</Color>
            <Color x:Key="SystemAccentColorLight1">#8B7CFF</Color>
            <Color x:Key="SystemAccentColorLight2">#A99DFF</Color>
            <Color x:Key="SystemAccentColorLight3">#C9C1FF</Color>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <!-- Component library: typography, buttons, cards, nav, badges -->
        <StyleInclude Source="/Themes/Controls.axaml" />
    </Application.Styles>
</Application>
